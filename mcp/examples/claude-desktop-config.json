{
    "mcpServers": {
        "chronoqueue": {
            "command": "npx",
            "args": [
                "-y",
                "@chronoqueue/mcp-server"
            ],
            "env": {
                "CHRONOQUEUE_ADDRESS": "localhost:9000",
                "CHRONOQUEUE_INSECURE": "true"
            }
        }
    }
}