{
    "mcpServers": {
        "chronoqueue": {
            "command": "node",
            "args": [
                "./dist/index.js"
            ],
            "cwd": "${workspaceFolder}/mcp",
            "env": {
                "CHRONOQUEUE_ADDRESS": "localhost:9000",
                "CHRONOQUEUE_INSECURE": "true"
            }
        }
    }
}