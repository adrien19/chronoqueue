{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://example.com/schemas/event.json",
    "title": "Event",
    "description": "Schema for system events",
    "type": "object",
    "required": [
        "event_type",
        "timestamp"
    ],
    "properties": {
        "event_type": {
            "type": "string",
            "enum": [
                "USER_REGISTERED",
                "USER_LOGGED_IN",
                "USER_LOGGED_OUT",
                "ORDER_CREATED",
                "ORDER_COMPLETED"
            ],
            "description": "Type of event"
        },
        "user_id": {
            "type": "string",
            "pattern": "^USER-[0-9]+$",
            "description": "User identifier"
        },
        "email": {
            "type": "string",
            "format": "email",
            "description": "User email address"
        },
        "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Event timestamp"
        },
        "metadata": {
            "type": "object",
            "description": "Additional event metadata"
        }
    }
}