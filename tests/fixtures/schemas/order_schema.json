{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://example.com/schemas/order.json",
    "title": "Order",
    "description": "Schema for order messages",
    "type": "object",
    "required": [
        "order_id",
        "customer_id",
        "total"
    ],
    "properties": {
        "order_id": {
            "type": "string",
            "pattern": "^ORD-[0-9]+$",
            "description": "Unique order identifier"
        },
        "customer_id": {
            "type": "string",
            "pattern": "^CUST-[0-9]+$",
            "description": "Customer identifier"
        },
        "items": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "sku",
                    "quantity",
                    "price"
                ],
                "properties": {
                    "sku": {
                        "type": "string",
                        "description": "Stock keeping unit"
                    },
                    "quantity": {
                        "type": "integer",
                        "minimum": 1,
                        "description": "Item quantity"
                    },
                    "price": {
                        "type": "number",
                        "minimum": 0,
                        "description": "Item price"
                    }
                }
            }
        },
        "total": {
            "type": "number",
            "minimum": 0,
            "description": "Total order amount"
        },
        "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Order creation timestamp"
        }
    }
}