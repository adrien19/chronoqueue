# AI Agent Orchestrator - Environment Variables
# Copy this file to .env and adjust values as needed

# Ollama Configuration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_HOST=0.0.0.0:11434

# ChronoQueue Configuration
CHRONOQUEUE_SERVER=chronoqueue:9000

# LLM Provider Configuration
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:3b
LLM_CODING_MODEL=qwen2.5-coder:7b

# Coordinator Configuration
COORDINATOR_WORKERS=2
COORDINATOR_VERBOSE=true

# Agent Configuration
AGENT_WORKERS=2
AGENT_VERBOSE=true

# Logging
LOG_LEVEL=info
LOG_FORMAT=text

# Optional: External Ollama (for development)
# Uncomment if using Ollama running on host machine
# OLLAMA_BASE_URL=http://host.docker.internal:11434
