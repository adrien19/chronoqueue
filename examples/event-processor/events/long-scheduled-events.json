{
    "events": [
        {
            "type": "email",
            "priority": "high",
            "schedule_in_minutes": 60,
            "data": {
                "recipient": "user@example.com",
                "subject": "Scheduled in 60 minutes - Meeting Reminder",
                "template": "meeting_reminder"
            }
        },
        {
            "type": "webhook",
            "priority": "medium",
            "schedule_in_minutes": 90,
            "data": {
                "webhook_url": "https://api.example.com/scheduled-callback",
