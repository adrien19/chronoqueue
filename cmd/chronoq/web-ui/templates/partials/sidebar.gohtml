{{ define "sidebar" }}<aside class="cq-sidebar px-4 py-5"><details class="group mb-6 px-2"><summary class="flex cursor-pointer list-none items-center gap-3 outline-none"><div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-blue-500/30 bg-blue-500/10 text-sm font-medium text-blue-300">CQ</div><div class="min-w-0 flex-1"><div class="truncate font-semibold text-white">{{ .EnvName }}</div><div class="truncate text-xs text-zinc-500">{{ .EnvSlug }}</div></div><svg class="h-3.5 w-3.5 shrink-0 text-zinc-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></summary><div class="mt-2 space-y-0.5 pl-[52px]">{{ range .Clusters }}{{ if not .IsActive }}<form method="POST" action="/api/clusters/{{ .Slug }}/switch"><button type="submit" class="cq-nav-link w-full py-1.5 text-left text-xs">{{ .Name }}<span class="ml-1 text-zinc-600">{{ .BrokerAddress }}</span></button></form>{{ end }}{{ end }}<a href="/settings/clusters/new" class="cq-nav-link block py-1.5 text-xs text-zinc-500 hover:text-blue-300">+ Add cluster</a></div></details><div class="mb-3 px-2 text-[11px] uppercase tracking-[0.2em] text-zinc-500">Console</div><nav class="space-y-1">{{ range .Nav }}<a href="{{ .Href }}" class="cq-nav-link {{ if eq $.Active .Key }}cq-nav-link-active{{ end }}">{{ .Label }}</a>{{ end }}</nav><div class="mt-10 px-2 text-[11px] uppercase tracking-[0.2em] text-zinc-500">Self-service</div><div class="mt-3 space-y-1"><a href="/settings/clusters" class="cq-nav-link opacity-90">Settings</a></div><div class="absolute bottom-4 left-4 right-4 flex items-center justify-between text-xs text-zinc-500"><span>ChronoQueue</span><span>{{ .Version }}</span></div></aside>{{ end }}

{{ define "settings_sidebar" }}<aside class="cq-sidebar px-4 py-5"><a href="/" class="mb-6 flex items-center gap-2 px-2 text-sm text-zinc-300 hover:text-white">← Back</a><div class="mt-2 px-2 pb-1 text-[11px] uppercase tracking-[0.2em] text-zinc-500">Advanced</div><div class="space-y-1">{{ range .SettingsNav }}{{ if eq .Section "Advanced" }}<a href="{{ .Href }}" class="cq-nav-link {{ if eq $.Active .Key }}cq-nav-link-active{{ end }} flex items-center justify-between"><span>{{ .Label }}</span>{{ if .Badge }}<span class="rounded border border-line px-1.5 py-0.5 text-[10px] uppercase tracking-[0.16em] text-zinc-400">{{ .Badge }}</span>{{ end }}</a>{{ end }}{{ end }}</div><div class="mt-8 px-2 pb-1 text-[11px] uppercase tracking-[0.2em] text-zinc-500">Your Organization</div><div class="space-y-1">{{ range .SettingsNav }}{{ if eq .Section "Your Organization" }}<a href="{{ .Href }}" class="cq-nav-link {{ if eq $.Active .Key }}cq-nav-link-active{{ end }} flex items-center justify-between"><span>{{ .Label }}</span>{{ if .Badge }}<span class="rounded border border-line px-1.5 py-0.5 text-[10px] uppercase tracking-[0.16em] text-zinc-400">{{ .Badge }}</span>{{ end }}</a>{{ end }}{{ end }}</div><div class="mt-8 px-2 pb-1 text-[11px] uppercase tracking-[0.2em] text-zinc-500">Account</div><div class="space-y-1">{{ range .SettingsNav }}{{ if eq .Section "Account" }}<a href="{{ .Href }}" class="cq-nav-link {{ if eq $.Active .Key }}cq-nav-link-active{{ end }} flex items-center justify-between"><span>{{ .Label }}</span>{{ if .Badge }}<span class="rounded border border-line px-1.5 py-0.5 text-[10px] uppercase tracking-[0.16em] text-zinc-400">{{ .Badge }}</span>{{ end }}</a>{{ end }}{{ end }}</div><div class="absolute bottom-4 left-4 right-4 flex items-center justify-between text-xs text-zinc-500"><span>ChronoQueue</span><span>{{ .Version }}</span></div></aside>{{ end }}
