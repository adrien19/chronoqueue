{{ define "topbar" }}<header class="mb-5 flex items-start justify-between gap-4"><div>{{ if ne .Layout "settings" }}<h1 class="text-2xl font-semibold tracking-tight text-white">{{ .PageTitle }}</h1><p class="mt-1 text-sm text-zinc-500">{{ .EnvName }} · {{ .BrokerAddress }}</p>{{ else }}<div class="h-10"></div>{{ end }}</div><div class="flex items-center gap-3"><button class="cq-btn">{{ .Version }}</button><a href="https://chronoqueue.io/docs" target="_blank" class="cq-btn">Docs</a><div class="flex h-10 w-10 items-center justify-center rounded-full border border-blue-500/30 bg-blue-500/10 text-sm font-medium text-blue-300">CQ</div></div></header>{{ end }}
