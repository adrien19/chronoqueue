{{ define "settings_clusters_content" }}<section class="space-y-6"><div class="flex items-start justify-between gap-4"><div><h2 class="text-3xl font-semibold text-white">Clusters</h2><p class="mt-1 text-sm text-zinc-500">Manage your ChronoQueue server connections.</p></div><a href="/settings/clusters/new" class="cq-btn cq-btn-primary">+ Add cluster</a></div><div class="border-t border-line pt-6 space-y-4">{{ range .Clusters }}<div class="cq-panel px-4 py-4"><div class="flex items-center justify-between gap-4"><div class="flex items-center gap-4"><div class="flex h-11 w-11 items-center justify-center rounded-full border border-blue-500/30 bg-blue-500/10 text-sm font-medium text-blue-300">CQ</div><div><div class="flex items-center gap-3"><a class="text-xl font-semibold text-white hover:text-blue-300" href="/settings/clusters/{{ .Slug }}">{{ .Name }}</a>{{ if .IsActive }}<span class="cq-badge cq-badge-good">Active</span>{{ end }}</div><div class="mt-1 text-sm text-zinc-500">{{ .BrokerAddress }}</div></div></div><div class="flex items-center gap-2"><a href="/settings/clusters/{{ .Slug }}" class="cq-btn">Edit</a>{{ if not .IsActive }}<form method="POST" action="/api/clusters/{{ .Slug }}/switch"><button type="submit" class="cq-btn">Switch</button></form><form method="POST" action="/api/clusters/{{ .Slug }}/delete" onsubmit="return confirm('Delete cluster {{ .Name }}?')"><button type="submit" class="cq-btn cq-btn-danger">Delete</button></form>{{ end }}</div></div></div>{{ else }}<div class="cq-panel p-8 text-zinc-400">No clusters configured. <a href="/settings/clusters/new" class="text-blue-400 hover:underline">Add one</a>.</div>{{ end }}</div></section>{{ end }}
