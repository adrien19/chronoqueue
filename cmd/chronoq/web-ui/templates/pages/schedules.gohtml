{{ define "schedules_content" }}
<section class="space-y-5">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h2 class="text-2xl font-semibold text-white">Schedules</h2>
      <p class="mt-1 text-sm text-zinc-500">Manage cron and calendar-based schedules</p>
    </div>
    <a href="/schedules/new" class="cq-btn cq-btn-primary">New schedule</a>
  </div>

  {{ if .HasMissingQueues }}
  <div class="rounded-lg border border-amber-500/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-300">
    <strong>Warning:</strong> Some schedules reference queues that don't exist. Messages won't be processed until queues are created.
    <a href="/queues" class="ml-2 underline hover:text-amber-100">Create queues →</a>
  </div>
  {{ end }}

  <div class="cq-panel overflow-hidden">
    <table class="cq-table">
      <thead>
        <tr>
          <th>Name</th><th>Type</th><th>Queue</th><th>Expression</th><th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{ range .Schedules }}
        <tr id="schedule-row-{{ .ScheduleId }}">
          <td class="font-medium text-white">{{ .ScheduleId }}</td>
          <td>
            {{ if .Metadata.GetCronSchedule }}
            <span class="cq-badge border-sky-500/25 bg-sky-500/10 text-sky-300">CRON</span>
            {{ else }}
            <span class="cq-badge border-purple-500/25 bg-purple-500/10 text-purple-300">CALENDAR</span>
            {{ end }}
          </td>
          <td>
            {{ .Metadata.QueueName }}
            {{ if not (index $.ExistingQueues .Metadata.QueueName) }}
            <span class="ml-1 cq-badge border-red-500/25 bg-red-500/10 text-red-300">⚠ Missing</span>
            {{ end }}
          </td>
          <td class="font-mono text-sm text-zinc-400">
            {{ if .Metadata.GetCronSchedule }}{{ .Metadata.GetCronSchedule }}{{ else }}Calendar{{ end }}
          </td>
          <td class="text-right">
            <div id="schedule-controls-{{ .ScheduleId }}" class="flex items-center justify-end gap-2">
              {{ if eq .Metadata.State.String "SCHEDULED" }}
              <span class="cq-badge cq-badge-good">Active</span>
              <button class="cq-btn !px-2 !py-1 text-xs"
                hx-post="/api/schedules/toggle"
                hx-vals='{"schedule_id": "{{ .ScheduleId }}", "action": "pause"}'
                hx-target="#schedule-controls-{{ .ScheduleId }}"
                hx-swap="outerHTML">Pause</button>
              {{ else if eq .Metadata.State.String "PAUSED" }}
              <span class="cq-badge cq-badge-warn">Paused</span>
              <button class="cq-btn cq-btn-primary !px-2 !py-1 text-xs"
                hx-post="/api/schedules/toggle"
                hx-vals='{"schedule_id": "{{ .ScheduleId }}", "action": "resume"}'
                hx-target="#schedule-controls-{{ .ScheduleId }}"
                hx-swap="outerHTML">Resume</button>
              {{ else }}
              <span class="cq-badge cq-badge-muted">{{ .Metadata.State }}</span>
              {{ end }}
              <button class="cq-btn !px-2 !py-1 text-xs text-red-300 border-red-500/20 hover:border-red-500/40"
                hx-delete="/api/schedules/{{ .ScheduleId }}"
                hx-confirm="Delete schedule '{{ .ScheduleId }}'?"
                hx-target="#schedule-row-{{ .ScheduleId }}"
                hx-swap="outerHTML">Delete</button>
            </div>
          </td>
        </tr>
        {{ end }}
        {{ if not .Schedules }}
        <tr><td colspan="5" class="py-8 text-center text-zinc-500">No schedules found. <a href="/schedules/new" class="text-blue-300">Create one →</a></td></tr>
        {{ end }}
      </tbody>
    </table>
  </div>
</section>
{{ end }}
