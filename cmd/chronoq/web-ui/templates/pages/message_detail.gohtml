{{ define "message_detail_content" }}
<section class="grid grid-cols-[1.3fr_1fr] gap-4">
  <div class="cq-panel p-6">
    <div class="mb-4 flex items-start justify-between gap-4">
      <div>
        <div class="mb-1 text-sm text-zinc-500"><a href="/queues" class="hover:text-white">Queues</a> / <a href="/queues/{{ .Message.Queue }}" class="hover:text-white">{{ .Message.Queue }}</a> / <span class="text-zinc-300">{{ .Message.ID }}</span></div>
        <div class="font-mono text-xl font-semibold text-white">{{ .Message.ID }}</div>
      </div>
    </div>
    <div class="grid grid-cols-4 gap-3">
      <div class="cq-panel-soft p-4"><div class="cq-label">Status</div><div class="mt-2"><span class="{{ statusClass .Message.Status }}">{{ .Message.Status }}</span></div></div>
      <div class="cq-panel-soft p-4"><div class="cq-label">Attempt</div><div class="mt-2 text-2xl font-semibold text-white">{{ .Message.Attempt }}</div></div>
      <div class="cq-panel-soft p-4"><div class="cq-label">Priority</div><div class="mt-2 text-2xl font-semibold text-white">{{ .Message.Priority }}</div></div>
      <div class="cq-panel-soft p-4"><div class="cq-label">Lease owner</div><div class="mt-2 text-sm font-medium text-white truncate">{{ if .Message.LeaseOwner }}{{ .Message.LeaseOwner }}{{ else }}—{{ end }}</div></div>
    </div>
    <div class="mt-5">
      <div class="mb-2 text-lg font-semibold text-white">Payload</div>
      <pre class="overflow-x-auto rounded-xl border border-line bg-zinc-950/80 p-4 text-sm text-zinc-200">{{ .Message.Payload }}</pre>
    </div>
  </div>
  <div class="space-y-4">
    <div class="cq-panel p-5">
      <div class="mb-3 text-lg font-semibold text-white">Metadata</div>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between gap-6"><dt class="text-zinc-500">Queue</dt><dd class="text-white"><a href="/queues/{{ .Message.Queue }}" class="text-blue-300">{{ .Message.Queue }}</a></dd></div>
        <div class="flex justify-between gap-6"><dt class="text-zinc-500">Created at</dt><dd class="text-white">{{ .Message.CreatedAt }}</dd></div>
        <div class="flex justify-between gap-6"><dt class="text-zinc-500">Visible at</dt><dd class="text-white">{{ .Message.VisibleAt }}</dd></div>
      </dl>
    </div>
  </div>
</section>
{{ end }}
