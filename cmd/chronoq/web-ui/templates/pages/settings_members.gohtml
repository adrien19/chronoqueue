{{ define "settings_members_content" }}
<section class="space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div><h2 class="text-3xl font-semibold text-white">Users</h2></div>
  </div>
  <div class="cq-panel p-7">
    <p class="text-lg font-semibold text-white">User management not configured. 🍃</p>
    <p class="mt-2 text-sm text-zinc-400">ChronoQueue self-hosted does not include a built-in user management system. Configure authentication via your infrastructure (reverse proxy, OAuth2 provider, etc.).</p>
  </div>
</section>{{ end }}
