{{ define "settings_profile_content" }}<section class="space-y-6"><div><h2 class="text-3xl font-semibold text-white">Profile</h2><p class="mt-2 text-sm text-zinc-400">This is a self-hosted ChronoQueue instance. Profile management is not applicable.</p></div><div class="cq-panel overflow-hidden"><div class="grid grid-cols-[1fr_auto] items-center gap-4 border-t border-line-soft p-6 first:border-t-0"><div><div class="text-lg font-semibold text-white">Server</div><div class="mt-1 text-sm text-zinc-400">{{ .BrokerAddress }}</div></div></div><div class="grid grid-cols-[1fr_auto] items-center gap-4 border-t border-line-soft p-6"><div><div class="text-lg font-semibold text-white">Version</div><div class="mt-1 text-sm text-zinc-400">{{ .Version }}</div></div></div></div></section>{{ end }}
