{{ define "settings_cluster_detail_content" }}<section class="space-y-5"><div class="flex items-start justify-between gap-4"><div><div class="mb-2 text-sm text-zinc-500"><a href="/settings/clusters" class="hover:text-white">Clusters</a> / <span class="text-zinc-300">{{ .Cluster.Slug }}</span></div><h2 class="text-4xl font-semibold text-white">{{ .Cluster.Name }}</h2></div></div>{{ if .Error }}<div class="cq-panel p-4 text-red-400 border-red-800">{{ .Error }}</div>{{ end }}<form method="POST" action="/api/clusters/{{ .Cluster.Slug }}" class="cq-panel p-5 space-y-5"><div><label class="mb-2 block text-sm font-medium text-zinc-200">Cluster name</label><input class="cq-input w-full" name="name" value="{{ .Cluster.Name }}" required></div><div><label class="mb-2 block text-sm font-medium text-zinc-200">Description</label><input class="cq-input w-full" name="description" value="{{ .Cluster.Description }}"></div><div><label class="mb-2 block text-sm font-medium text-zinc-200">ChronoQueue endpoint</label><input class="cq-input w-full" name="brokerAddress" value="{{ .Cluster.BrokerAddress }}" placeholder="localhost:50051" required><p class="mt-2 text-xs text-zinc-500">The gRPC address this server is listening on.</p></div><div class="flex items-center gap-3"><input type="checkbox" id="skipSSLCheck" name="skipSSLCheck" class="h-4 w-4 rounded" {{ if .Cluster.SkipSSLCheck }}checked{{ end }}><label for="skipSSLCheck" class="text-sm text-zinc-200">Skip TLS certificate verification</label></div><div class="border-t border-line pt-5 flex items-center gap-4"><button type="submit" class="cq-btn cq-btn-primary">Save changes</button><a href="/settings/clusters" class="cq-btn">Cancel</a></div></form></section>{{ end }}
