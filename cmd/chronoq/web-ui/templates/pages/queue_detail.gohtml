{{ define "queue_detail_content" }}
<section class="space-y-5">
  <div class="cq-panel p-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <div class="mb-1 text-sm text-zinc-500">
          <a href="/queues" class="hover:text-white">Queues</a>
          {{ if .Queue.SourceQueue }} / <a href="/queues/{{ .Queue.SourceQueue }}" class="hover:text-white">{{ .Queue.SourceQueue }}</a>{{ end }}
          / <span class="text-zinc-300">{{ .Queue.Name }}</span>
        </div>
        <div class="text-3xl font-semibold text-white">{{ .Queue.Name }}</div>
        {{ if .Queue.IsDLQ }}
        <div class="mt-2 flex items-center gap-3">
          <span class="cq-badge border-red-500/25 bg-red-500/10 text-red-300">DLQ</span>
          {{ if .Queue.SourceQueue }}
          <a href="/queues/{{ .Queue.SourceQueue }}" class="flex items-center gap-1 text-sm text-zinc-400 hover:text-white">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Source: {{ .Queue.SourceQueue }}
          </a>
          {{ end }}
        </div>
        {{ end }}
      </div>
      <div class="flex gap-2">
        {{ if .Queue.DLQName }}
        <a href="/queues/{{ .Queue.DLQName }}" class="cq-btn flex items-center gap-1.5">
          <span class="inline-block h-2 w-2 rounded-full bg-red-400"></span>
          View DLQ
        </a>
        {{ end }}
        {{ if .Queue.IsDLQ }}
        <form method="POST" action="/queues/{{ .Queue.Name }}/requeue-all" onsubmit="return confirm('Requeue all messages from DLQ back to {{ .Queue.SourceQueue }}?')">
          <button class="cq-btn cq-btn-primary" type="submit">Requeue all</button>
        </form>
        {{ end }}
        <form method="POST" action="/queues/{{ .Queue.Name }}/purge" onsubmit="return confirm('Purge ALL messages from this queue? This cannot be undone.')">
          <button class="cq-btn" type="submit">Purge</button>
        </form>
      </div>
    </div>
    <div class="mt-6 grid grid-cols-5 gap-3">
      <div class="cq-panel-soft p-4"><div class="cq-label">Ready</div><div class="mt-2 text-2xl font-semibold text-blue-300">{{ .Queue.Ready }}</div></div>
      <div class="cq-panel-soft p-4"><div class="cq-label">Inflight</div><div class="mt-2 text-2xl font-semibold text-white">{{ .Queue.InFlight }}</div></div>
      <div class="cq-panel-soft p-4"><div class="cq-label">Retries</div><div class="mt-2 text-2xl font-semibold text-amber-300">{{ .Queue.Retries }}</div></div>
      <div class="cq-panel-soft p-4"><div class="cq-label">DLQ</div><div class="mt-2 text-2xl font-semibold text-red-300">{{ .Queue.DLQ }}</div></div>
      <div class="cq-panel-soft p-4"><div class="cq-label">Completed</div><div class="mt-2 text-2xl font-semibold text-white">{{ .Queue.Completed }}</div></div>
    </div>
  </div>

  <div class="cq-panel overflow-hidden">
    <div class="flex items-center justify-between border-b border-line px-5 py-4">
      <div class="text-lg font-semibold text-white">Messages</div>
      <div class="flex items-center gap-3">
        <span class="text-sm text-zinc-500">showing up to 100</span>
        {{ if not .Queue.IsDLQ }}
        <a href="/queues/{{ .Queue.Name }}/messages/new" class="cq-btn cq-btn-primary">New message</a>
        {{ end }}
      </div>
    </div>
    {{ template "message_table" . }}
  </div>
</section>
{{ end }}
