{{ define "workers_content" }}
<section class="space-y-5">
  <div class="cq-panel p-8 text-center">
    <div class="mx-auto max-w-md">
      <div class="mb-4 text-4xl">⚙️</div>
      <h2 class="text-xl font-semibold text-white">Workers are external processes</h2>
      <p class="mt-3 text-sm leading-6 text-zinc-400">
        ChronoQueue workers are client applications that connect to the server and dequeue messages. They run independently and are not managed by this dashboard.
      </p>
      <p class="mt-3 text-sm text-zinc-500">
        Use the <a href="/lease-monitor" class="text-blue-300 hover:text-blue-200">Lease monitor</a> to see messages currently being processed by workers.
      </p>
      <div class="mt-6 flex justify-center gap-3">
        <a href="/lease-monitor" class="cq-btn">Lease monitor</a>
        <a href="/queues" class="cq-btn">View queues</a>
      </div>
    </div>
  </div>
</section>
{{ end }}
